# Gemini API Key (Required for backend proxy)
GEMINI_API_KEY=

# Optional: Custom Gemini API Base URL (if using a proxy)
GEMINI_BASE_URL=
GEMINI_LIVE_WS_URL=

# Frontend Configuration (For GitHub Pages deployment)
# Set this to the URL of your deployed backend server (e.g., https://my-backend.onrender.com)
# Leave empty if running locally where frontend and backend are on the same server
VITE_API_BASE_URL=

# Frontend API Keys and URLs (Optional, for direct client-side calls)
VITE_GEMINI_API_KEY=
VITE_GEMINI_BASE_URL=
VITE_GEMINI_LIVE_WS_URL=

VITE_ALIYUN_API_KEY=
VITE_ALIYUN_API_URL=

VITE_MIMO_API_KEY=
VITE_MIMO_API_URL=